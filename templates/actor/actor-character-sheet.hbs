<div class="{{cssClass}} {{actor.type}}  window-scroll-body" autocomplete="off">

  <header class="sheet-header">
    <img
      class="profile-img"
      src="{{actor.img}}"
      data-edit="img"
      title="{{actor.name}}"
      height="100"
      width="100"
    />

    <div class="header-fields">

      <h1 class="charname">
        <input
        id="name"
          name="name"
          type="text"
          value="{{actor.name}}"
          placeholder="Name"
        />
      </h1>
      <h3 class="frame">
        {{localize config.Sections.frame}}
        <br />
        <input
        id="frame"
          name="frame"
          type="text"
          value="{{actor.frame}}"
          placeholder="Frame"
        />
      </h3>

      <div class="resources grid grid-3col">

        <div class="resource flex-group-center">
          <label for="boost-move" class="resource-label">
            {{localize config.Sections.boostMove}}
          </label>

          <div class="resource-content flexrow flex-center flex-between">
            <input
              id="boost-move"
              type="text"
              name="system.boostMove.value"
              value="{{system.boostMove.value}}"
              data-dtype="Number"
            />

            <span>까지</span>

            <input
              id="boost-move-cost"
              type="text"
              name="system.boostMove.cost"
              value="{{system.boostMove.cost}}"
              data-dtype="Number"
            />
          </div>
          <span>개</span>
        </div>

        <div class="resource flex-group-center">
          <label for="normal-move" class="resource-label">
            {{localize config.Sections.normalMove}}
          </label>

          <div class="resource-content flexrow flex-center flex-between">
            <input
              id="normal-move"
              type="text"
              name="system.normalMove.value"
              value="{{system.normalMove.value}}"
              data-dtype="Number"
            />

            <span>/</span>

            <input
              id="normal-move-cost"
              type="text"
              name="system.normalMove.cost"
              value="{{system.normalMove.cost}}"
              data-dtype="Number"
            />
          </div>
        </div>

        <div class="resource flex-group-center">
          <label for="energy-value" class="resource-label">
            {{localize config.Sections.energy}}
          </label>

          <div class="resource-content flexrow flex-center flex-between">
            <input
              id="energy-value"
              type="text"
              name="system.attributes.energy.value"
              value="{{system.attributes.energy.value}}"
              data-dtype="Number"
            />
          </div>
        </div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">

    <a
      class="item {{tabs.features.cssClass}}"
      data-action="changeTab"
      data-tab="sheet">
      {{localize tabs.sheet.label}}
    </a>

    <a
      class="item {{tabs.description.cssClass}}"
      data-action="changeTab"
      data-tab="achievementArchive">
      {{localize tabs.achievementArchive.label}}
    </a>

    <a
      class="item {{tabs.items.cssClass}}"
      data-action="changeTab"
      data-tab="weaponArchive">
      {{localize tabs.weaponArchive.label}}
    </a>

    <a
      class="item {{tabs.spells.cssClass}}"
      data-action="changeTab"
      data-tab="chronicleArchive">
      {{localize tabs.chronicleArchive.label}}
    </a>

    <a
      class="item {{tabs.effects.cssClass}}"
      data-action="changeTab"
      data-tab="engagementArchive">
      {{localize tabs.engagementArchive.label}}
    </a>

  </nav>

  <section class="sheet-body">

    <div
      class="tab features {{tabs.features.cssClass}}"
      data-group="primary"
      data-tab="features">

      <section class="grid grid-3col">

        <aside class="sidebar">

          <div class="abilities flexcol">

            {{#each system.abilities as |ability key|}}

            <div class="ability flexrow flex-group-center">

              <label
                for="ability-{{key}}"
                class="resource-label rollable flexlarge align-left"
                data-action="roll"
                data-roll="d20+@abilities.{{key}}.mod"
                data-label="{{localize (lookup @root.config.abilities key)}}">

                {{localize (lookup @root.config.abilities key)}}

              </label>

              <input
                id="ability-{{key}}"
                type="text"
                name="system.abilities.{{key}}.value"
                value="{{ability.value}}"
                data-dtype="Number"
              />

              <span
                class="ability-mod rollable"
                data-action="roll"
                data-roll="d20+@abilities.{{key}}.mod"
                data-label="{{localize (lookup @root.config.abilities key)}}">

                {{numberFormat ability.mod decimals=0 sign=true}}

              </span>

            </div>

            {{/each}}

          </div>

        </aside>

        <section class="main grid-span-2">
          {{> "systems/fvtt-revulture/templates/actor/parts/actor-features.hbs"}}
        </section>

      </section>

    </div>
<div
  class="tab description {{tabs.description.cssClass}}"
  data-group="primary"
  data-tab="description">

  <textarea name="system.biography" rows="12">{{system.biography}}</textarea>

</div>

    <div
      class="tab items {{tabs.items.cssClass}}"
      data-group="primary"
      data-tab="items">

      {{> "systems/fvtt-revulture/templates/actor/parts/actor-items.hbs"}}

    </div>

    <div
      class="tab spells {{tabs.spells.cssClass}}"
      data-group="primary"
      data-tab="spells">

      {{> "systems/fvtt-revulture/templates/actor/parts/actor-spells.hbs"}}

    </div>

    <div
      class="tab effects flexcol {{tabs.effects.cssClass}}"
      data-group="primary"
      data-tab="effects">

      {{> "systems/fvtt-revulture/templates/actor/parts/actor-effects.hbs"}}

    </div>

    <div
      class="tab effects flexcol {{tabs.effects.cssClass}}"
      data-group="primary"
      data-tab="effects">

      {{> "systems/fvtt-revulture/templates/actor/parts/actor-effects.hbs"}}

    </div>

  </section>

</div>