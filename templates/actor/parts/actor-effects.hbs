<ol class="items-list effects-list">

  {{#each effects as |section|}}
    <li
      class="items-header flexrow"
      data-effect-type="{{section.type}}"
      data-parent-id="{{@root.actor.id}}"
    >
      <h3 class="item-name effect-name flexrow">
        {{localize section.label}}
      </h3>

      <div class="effect-source">
        {{localize "FVTT_REVULTURE.Effect.Source"}}
      </div>

      <div class="effect-duration">
        {{localize "EFFECT.TabDuration"}}
      </div>

      <div class="item-controls effect-controls flexrow">
        <a
          class="effect-control"
          data-action="effectCreate"
          data-effect-type="{{section.type}}"
          title="{{localize 'DOCUMENT.Create'}}"
        >
          <i class="fas fa-plus"></i>
          {{localize "DOCUMENT.New"}}
        </a>
      </div>
    </li>

    <ol class="item-list">
      {{#each section.effects as |effect|}}

        <li
          class="item effect flexrow"
          data-effect-id="{{effect.id}}"
          data-parent-id="{{effect.parent.id}}"
        >

          <div class="item-name effect-name flexrow">
            <img
              class="item-image"
              src="{{effect.img}}"
              title="{{effect.name}}"
              width="24"
              height="24"
            />

            <h4>{{effect.name}}</h4>
          </div>

          <div class="effect-source">
            {{effect.sourceName}}
          </div>

          <div class="effect-duration">
            {{effect.duration.label}}
          </div>

          <div class="item-controls effect-controls flexrow">

            <a
              class="effect-control"
              data-action="effectToggle"
              data-effect-id="{{effect.id}}"
              title="{{localize 'FVTT_REVULTURE.Effect.Toggle'}}"
            >
              <i class="fas {{#if effect.disabled}}fa-check{{else}}fa-times{{/if}}"></i>
            </a>

            <a
              class="effect-control"
              data-action="effectEdit"
              data-effect-id="{{effect.id}}"
              title="{{localize 'DOCUMENT.Update'}}"
            >
              <i class="fas fa-edit"></i>
            </a>

            <a
              class="effect-control"
              data-action="effectDelete"
              data-effect-id="{{effect.id}}"
              title="{{localize 'DOCUMENT.Delete'}}"
            >
              <i class="fas fa-trash"></i>
            </a>

          </div>

        </li>

      {{/each}}
    </ol>

  {{/each}}

</ol>